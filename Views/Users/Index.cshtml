@model IEnumerable<KT9_Admin_Panel_MVC.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Users";
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = User.IsInRole("Admin");
}

<h1>Users</h1>

@if (isAdmin)
{
    <p><a asp-action="Create" class="btn btn-primary">Create New User</a></p>
}

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Roles</th>
            @if (isAdmin)
            {
                <th>Actions</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>
                <td>
                    @if (ViewBag.UserRoles != null && ViewBag.UserRoles.ContainsKey(item.Id))
                    {
                        @string.Join(", ", ViewBag.UserRoles[item.Id])
                    }
                </td>
                @if (isAdmin)
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>